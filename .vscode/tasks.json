{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "msvc-x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Debug",
                "--target",
                "InteractiveStreams",
                "--",
                "/verbosity:minimal"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "CMake: Build (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Release",
                "--target",
                "InteractiveStreams",
                "--",
                "/verbosity:minimal"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "CMake: Clean & Rebuild (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Debug",
                "--clean-first",
                "--target",
                "InteractiveStreams",
                "--",
                "/verbosity:minimal"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "CMake: Build Tests (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Debug",
                "--target",
                "InteractiveStreams_Tests",
                "--",
                "/verbosity:minimal"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "CMake: Run Tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--output-on-failure",
                "-C",
                "Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "dependsOn": "CMake: Build Tests (Debug)",
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Run InteractiveStreams (Release)",
            "type": "shell",
            "command": "${workspaceFolder}/build/Release/InteractiveStreams.exe",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}/build/Release"
            },
            "dependsOn": "CMake: Build (Release)",
            "problemMatcher": []
        }
    ]
}