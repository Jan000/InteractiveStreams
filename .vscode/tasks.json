{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Dashboard: Build (if changed)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-Command",
                "$webDir = '${workspaceFolder}/web'; $outDir = \"$webDir/out\"; $srcDir = \"$webDir/src\"; $stamp = \"$outDir/.build-stamp\"; $needsBuild = $false; if (-not (Test-Path $outDir)) { $needsBuild = $true } elseif (-not (Test-Path $stamp)) { $needsBuild = $true } else { $stampTime = (Get-Item $stamp).LastWriteTime; $changed = Get-ChildItem -Path $srcDir -Recurse -File | Where-Object { $_.LastWriteTime -gt $stampTime }; $pkgJson = Get-Item \"$webDir/package.json\"; if ($changed -or $pkgJson.LastWriteTime -gt $stampTime) { $needsBuild = $true } }; if ($needsBuild) { Write-Host '>>> Dashboard sources changed – rebuilding...'; Push-Location $webDir; bun install --frozen-lockfile 2>$null; if ($LASTEXITCODE -ne 0) { bun install }; bun run build; if ($LASTEXITCODE -ne 0) { Pop-Location; exit 1 }; New-Item -ItemType File -Path $stamp -Force | Out-Null; Pop-Location; Write-Host '>>> Dashboard build complete.' } else { Write-Host '>>> Dashboard is up-to-date, skipping build.' }"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Stop InteractiveStreams (if running)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-Command",
                "Stop-Process -Name InteractiveStreams -Force -ErrorAction SilentlyContinue; Start-Sleep -Milliseconds 500"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "msvc-x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Debug",
                "--target",
                "InteractiveStreams",
                "--",
                "/verbosity:minimal"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Dashboard: Build (if changed)", "Stop InteractiveStreams (if running)"],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "CMake: Build (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Release",
                "--target",
                "InteractiveStreams",
                "--",
                "/verbosity:minimal"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Dashboard: Build (if changed)", "Stop InteractiveStreams (if running)"],
            "dependsOrder": "parallel",
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "CMake: Clean & Rebuild (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Debug",
                "--clean-first",
                "--target",
                "InteractiveStreams",
                "--",
                "/verbosity:minimal"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Dashboard: Build (if changed)", "Stop InteractiveStreams (if running)"],
            "dependsOrder": "parallel",
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "CMake: Build Tests (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Debug",
                "--target",
                "InteractiveStreams_Tests",
                "--",
                "/verbosity:minimal"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "CMake: Run Tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--output-on-failure",
                "-C",
                "Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "dependsOn": "CMake: Build Tests (Debug)",
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Run InteractiveStreams (Release)",
            "type": "shell",
            "command": "${workspaceFolder}/build/Release/InteractiveStreams.exe",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}/build/Release"
            },
            "dependsOn": "CMake: Build (Release)",
            "problemMatcher": []
        }
    ]
}