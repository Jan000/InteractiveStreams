{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "msvc-x64",
            "displayName": "MSVC x64",
            "description": "Visual Studio 2022, 64-bit (default)",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "20",
                "IS_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "msvc-x86",
            "displayName": "MSVC x86",
            "description": "Visual Studio 2022, 32-bit",
            "generator": "Visual Studio 17 2022",
            "architecture": "Win32",
            "binaryDir": "${sourceDir}/build-x86",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "20",
                "IS_BUILD_TESTS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Debug (x64)",
            "configurePreset": "msvc-x64",
            "configuration": "Debug"
        },
        {
            "name": "release",
            "displayName": "Release (x64)",
            "configurePreset": "msvc-x64",
            "configuration": "Release"
        },
        {
            "name": "debug-x86",
            "displayName": "Debug (x86)",
            "configurePreset": "msvc-x86",
            "configuration": "Debug"
        },
        {
            "name": "release-x86",
            "displayName": "Release (x86)",
            "configurePreset": "msvc-x86",
            "configuration": "Release"
        }
    ],
    "testPresets": [
        {
            "name": "test",
            "displayName": "All Tests (x64 Debug)",
            "configurePreset": "msvc-x64",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
